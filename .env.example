# Copy this file to .env and fill in your values.
# On Windows, set these in PowerShell before starting the server:
#   $env:GCP_PROJECT_ID = "your-project-id"
#   $env:FFMPEG_PATH = "C:\path\to\ffmpeg.exe"

# Your Google Cloud project ID (find it at console.cloud.google.com)
GCP_PROJECT_ID=your-gcp-project-id

# Full path to ffmpeg binary.
# On Mac/Linux with ffmpeg in PATH, leave this unset.
# On Windows, set to the full path, e.g.:
# FFMPEG_PATH=C:\Users\YourName\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg_...\bin\ffmpeg.exe
FFMPEG_PATH=ffmpeg
